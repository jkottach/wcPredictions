# Example nginx site — copy and customize for your domain.
#
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/predictions
#   sudo ln -sf /etc/nginx/sites-available/predictions /etc/nginx/sites-enabled/
#   # Edit server_name and root paths, then:
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d predictions.yourcompany.com

server {
    listen 80;
    server_name predictions.yourcompany.com;

    # Path to your cloned repo's frontend build output
    root /var/www/predictions/frontend/dist;
    index index.html;

    # SPA — React Router
    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:5001/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Required for JWT auth
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-Access-Token $http_x_access_token;
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Set-Cookie;
    }

    location /assets/ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}
