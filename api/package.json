{
  "name": "kanhans-fifa26-api",
  "version": "1.0.0",
  "description": "Fifa26 API — Express + MongoDB, Azure Functions for production",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "seed": "tsx scripts/seedMongo.ts",
    "seed:mongo": "tsx scripts/seedMongo.ts",
    "seed:export": "tsx scripts/exportSeedFromDb.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@azure/functions": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
