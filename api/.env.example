# Copy to api/.env on your machine or EC2. Do not commit real secrets.
# EC2: see EC2_DEPLOYMENT.md | Azure: see AZURE_DEPLOYMENT.md

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=fifaPrediction

JWT_SECRET=change_to_long_random_secret
JWT_EXPIRE=7d

GOOGLE_CLIENT_ID=your-fifa-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

NODE_ENV=production
FRONTEND_URL=https://wc26.kanhans.com

# Tournament bracket picks close Jun 18, 2026 (override optional)
TOURNAMENT_PREDICTION_DEADLINE=2026-06-18T23:59:59.000Z

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Optional (local dev only — not required on Azure Functions)
PORT=5001
