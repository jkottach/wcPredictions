# Copy these names + values into Azure Static Web App → Environment variables (Production).
# Do not commit real secrets. Use the same values as your local api/.env where applicable.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=fifaPrediction

JWT_SECRET=change_to_long_random_secret
JWT_EXPIRE=7d

GOOGLE_CLIENT_ID=your-fifa-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

NODE_ENV=production
FRONTEND_URL=https://blue-plant-0ba785610.7.azurestaticapps.net

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Optional (local dev only — not required on Azure Functions)
PORT=5001
