{
  "name": "fifa26-predictor-backend",
  "version": "1.0.0",
  "description": "Backend API for Fifa26 Prediction System",
  "main": "src/index.ts",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "seed:communities": "tsx scripts/seedCommunities.ts",
    "seed:users": "tsx scripts/seedUsers.ts",
    "seed:teams": "tsx scripts/seedTeams.ts",
    "seed:matches": "tsx scripts/seedMatches.ts",
    "seed:leaderboards": "tsx scripts/seedLeaderboards.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
