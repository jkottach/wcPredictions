generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                   @id @default(autoincrement())
  userId           String                @unique @db.NVarChar(128)
  email            String                @unique @db.NVarChar(255)
  firstName        String                @db.NVarChar(200)
  lastName         String                @db.NVarChar(200)
  password         String?               @db.NVarChar(255)
  status           String                @default("active") @db.NVarChar(20)
  creationTime     DateTime              @default(now())
  phoneNumber      String?               @db.NVarChar(50)
  city             String                @default("") @db.NVarChar(200)
  state            String                @default("") @db.NVarChar(200)
  country          String                @default("") @db.NVarChar(200)
  comment          String?               @db.NVarChar(Max)
  communityId1     String?               @db.NVarChar(128)
  communityId2     String?               @db.NVarChar(128)
  isActive         Boolean               @default(true)
  googleId         String?               @db.NVarChar(255)
  instagramId      String?               @db.NVarChar(255)
  profileImage     String?               @db.NVarChar(500)
  role             String                @default("user") @db.NVarChar(20)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  predictions      Prediction[]
  results          Result[]
  communityRequest UserCommunityRequest?

  @@map("users")
}

model UserCommunityRequest {
  userId              String @id @db.NVarChar(128)
  user                User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  name                String @db.NVarChar(500)
  shortName           String @default("") @db.NVarChar(500)
  description         String @default("") @db.NVarChar(Max)
  isOnline            Boolean @default(false)
  city                String @default("") @db.NVarChar(200)
  state               String @default("") @db.NVarChar(200)
  existingCommunityId String? @db.NVarChar(128)

  @@map("user_community_requests")
}

model Community {
  id           Int      @id @default(autoincrement())
  communityId  String   @unique @db.NVarChar(128)
  name         String   @db.NVarChar(500)
  fullName     String?  @db.NVarChar(500)
  isOnline     Boolean  @default(false)
  state        String   @db.NVarChar(200)
  city         String   @db.NVarChar(200)
  address      String   @default("") @db.NVarChar(500)
  description  String?  @db.NVarChar(Max)
  creationTime DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("communities")
}

model Team {
  id          Int      @id @default(autoincrement())
  teamId      String   @unique @db.NVarChar(64)
  teamName    String   @db.NVarChar(200)
  country     String   @db.NVarChar(200)
  coach       String?  @db.NVarChar(200)
  foundedYear Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("teams")
}

model Match {
  id                    Int      @id @default(autoincrement())
  matchId               String   @unique @db.NVarChar(128)
  sequence              Int
  team1                 String   @db.NVarChar(64)
  team2                 String   @db.NVarChar(64)
  team1Score            Int?
  team2Score            Int?
  matchTime             DateTime
  predictionsEndingTime DateTime
  round                 Int
  comment               String?  @db.NVarChar(Max)
  matchTag              String   @db.NVarChar(200)
  status                String   @default("scheduled") @db.NVarChar(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  predictions           Prediction[] @relation("MatchPredictions")
  results               Result[]     @relation("MatchResults")

  @@map("matches")
}

model Prediction {
  id             Int      @id @default(autoincrement())
  userId         String   @db.NVarChar(128)
  user           User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  email          String   @db.NVarChar(255)
  matchId        String   @db.NVarChar(128)
  match          Match    @relation("MatchPredictions", fields: [matchId], references: [matchId], onDelete: NoAction, onUpdate: NoAction)
  matchTag       String   @db.NVarChar(200)
  team1Score     Int
  team2Score     Int
  submittedTime  DateTime @default(now())
  points         Int      @default(0)
  comment        String?  @db.NVarChar(Max)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, matchId])
  @@map("predictions")
}

model Result {
  id             Int      @id @default(autoincrement())
  userId         String   @db.NVarChar(128)
  user           User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userName       String   @db.NVarChar(400)
  matchId        String   @db.NVarChar(128)
  match          Match    @relation("MatchResults", fields: [matchId], references: [matchId], onDelete: NoAction, onUpdate: NoAction)
  matchTag       String   @db.NVarChar(200)
  result         String   @db.NVarChar(20)
  matchPoints    Int      @default(0)
  finalPoints    Int      @default(0)
  communityId1   String?  @db.NVarChar(128)
  communityId2   String?  @db.NVarChar(128)
  dailyRank      Int?
  finalRank      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@map("results")
}

model CommunityResult {
  id                      Int      @id @default(autoincrement())
  communityId             String   @db.NVarChar(128)
  communityWeightagePoint Int      @default(1)
  matchId                 String   @db.NVarChar(128)
  matchTag                String   @db.NVarChar(200)
  communityMatchPoint     Int      @default(0)
  totalCommunityPoint     Int      @default(0)
  dailyRank               Int?
  finalRank               Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([communityId, matchId])
  @@map("community_results")
}

model TopLeader {
  id           Int      @id @default(autoincrement())
  rank         Int
  totalPoints  Int
  name         String   @db.NVarChar(400)
  state        String   @default("") @db.NVarChar(200)
  community1   String?  @db.NVarChar(500)
  community2   String?  @db.NVarChar(500)
  userId       String   @db.NVarChar(128)
  email        String   @db.NVarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("top_leaders")
}

model DailyLeader {
  id           Int      @id @default(autoincrement())
  rank         Int
  totalPoints  Int
  name         String   @db.NVarChar(400)
  state        String   @default("") @db.NVarChar(200)
  community1   String?  @db.NVarChar(500)
  community2   String?  @db.NVarChar(500)
  userId       String   @db.NVarChar(128)
  email        String   @db.NVarChar(255)
  date         DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([userId])
  @@map("daily_leaders")
}

model CommunityLeader {
  id             Int      @id @default(autoincrement())
  rank           Int
  totalPoints    Int
  communityName  String   @db.NVarChar(500)
  communityId    String   @db.NVarChar(128)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([communityId])
  @@map("community_leaders")
}

model DailyCommunityLeader {
  id              Int      @id @default(autoincrement())
  rank            Int
  totalPoints     Int
  communityName   String   @db.NVarChar(500)
  communityId     String   @db.NVarChar(128)
  date            DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([communityId, date])
  @@map("daily_community_leaders")
}
