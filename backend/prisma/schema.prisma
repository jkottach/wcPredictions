generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                   @id @default(autoincrement())
  email            String                @unique @db.VarChar(255)
  firstName        String                @db.VarChar(200)
  lastName         String                @db.VarChar(200)
  status           String                @default("active") @db.VarChar(20)
  creationTime     DateTime              @default(now())
  phoneNumber      String?               @db.VarChar(50)
  city             String                @default("") @db.VarChar(200)
  state            String                @default("") @db.VarChar(200)
  country          String                @default("") @db.VarChar(200)
  comment          String?               @db.LongText
  communityId1     Int?
  communityId2     Int?
  community1       Community?            @relation("UserCommunity1", fields: [communityId1], references: [id], onDelete: SetNull, onUpdate: Cascade)
  community2       Community?            @relation("UserCommunity2", fields: [communityId2], references: [id], onDelete: SetNull, onUpdate: Cascade)
  isActive         Boolean               @default(true)
  googleId         String?               @db.VarChar(255)
  instagramId      String?               @db.VarChar(255)
  profileImage     String?               @db.VarChar(500)
  role             String                @default("user") @db.VarChar(20)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  predictions      Prediction[]
  results          Result[]
  finalUserResult  FinalUserResult?
  communityRequest UserCommunityRequest?

  @@map("users")
}

model UserCommunityRequest {
  userId              Int     @id
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String  @db.VarChar(500)
  shortName           String  @default("") @db.VarChar(500)
  description         String  @default("") @db.VarChar(2000)
  isOnline            Boolean @default(false)
  city                String  @default("") @db.VarChar(200)
  state               String  @default("") @db.VarChar(200)
  existingCommunityId String? @db.VarChar(128)

  @@map("user_community_requests")
}

model Community {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(500)
  fullName     String?  @db.VarChar(500)
  isOnline     Boolean  @default(false)
  state        String   @db.VarChar(200)
  city         String   @db.VarChar(200)
  address      String   @default("") @db.VarChar(500)
  description  String?  @db.LongText
  creationTime DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  usersAsCommunity1 User[] @relation("UserCommunity1")
  usersAsCommunity2 User[] @relation("UserCommunity2")

  @@map("communities")
}

model Team {
  id          Int      @id @default(autoincrement())
  teamId      String   @unique @db.VarChar(64)
  teamName    String   @db.VarChar(200)
  country     String   @db.VarChar(200)
  countryLogo String?  @db.VarChar(500)
  coach       String?  @db.VarChar(200)
  foundedYear Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("teams")
}

model Match {
  id                    Int      @id @default(autoincrement())
  sequence              Int
  team1                 String   @db.VarChar(64)
  team2                 String   @db.VarChar(64)
  team1Score            Int?
  team2Score            Int?
  matchTime             DateTime
  predictionsEndingTime DateTime
  round                 String   @db.VarChar(100)
  group                 String?  @map("group") @db.VarChar(100)
  comment               String?  @db.LongText
  matchTag              String   @db.VarChar(200)
  status                String   @default("scheduled") @db.VarChar(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  predictions           Prediction[] @relation("MatchPredictions")
  results               Result[]     @relation("MatchResults")

  @@map("matches")
}

model Prediction {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId        Int
  match          Match    @relation("MatchPredictions", fields: [matchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  matchTag       String   @db.VarChar(200)
  team1Score     Int
  team2Score     Int
  submittedTime  DateTime @default(now())
  points         Int      @default(0)
  comment        String?  @db.LongText
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, matchId])
  @@map("predictions")
}

model Result {
  id                     Int      @id @default(autoincrement())
  userId                 Int
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId                Int
  match                  Match    @relation("MatchResults", fields: [matchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  matchTag               String   @db.VarChar(200)
  result                 String   @db.VarChar(20)
  matchPoints            Int      @default(0)
  finalPoints            Int      @default(0)
  communityName1         String?  @db.VarChar(500)
  communityName2         String?  @db.VarChar(500)
  team1PredictedScore    Int?
  team2PredictedScore    Int?
  dailyRank              Int?
  finalRank              Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@map("results")
}

model FinalUserResult {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  finalPoint  Int      @default(0)
  finalRank   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("final_user_results")
}

model CommunityResult {
  id                      Int      @id @default(autoincrement())
  communityId             String   @db.VarChar(128)
  communityWeightagePoint Int      @default(1)
  matchId                 Int
  matchTag                String   @db.VarChar(200)
  communityMatchPoint     Int      @default(0)
  totalCommunityPoint     Int      @default(0)
  dailyRank               Int?
  finalRank               Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([communityId, matchId])
  @@map("community_results")
}

model TopLeader {
  id           Int      @id @default(autoincrement())
  rank         Int
  totalPoints  Int
  name         String   @db.VarChar(400)
  state        String   @default("") @db.VarChar(200)
  community1   String?  @db.VarChar(500)
  community2   String?  @db.VarChar(500)
  userId       String   @db.VarChar(128)
  email        String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("mv_top_leaders")
}

model DailyLeader {
  id           Int      @id @default(autoincrement())
  rank         Int
  totalPoints  Int
  name         String   @db.VarChar(400)
  state        String   @default("") @db.VarChar(200)
  community1   String?  @db.VarChar(500)
  community2   String?  @db.VarChar(500)
  userId       String   @db.VarChar(128)
  email        String   @db.VarChar(255)
  date         DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([userId])
  @@map("mv_daily_leaders")
}

model CommunityLeader {
  id             Int      @id @default(autoincrement())
  rank           Int
  totalPoints    Int
  communityName  String   @db.VarChar(500)
  communityId    String   @db.VarChar(128)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([communityId])
  @@map("mv_community_leaders")
}

model DailyCommunityLeader {
  id              Int      @id @default(autoincrement())
  rank            Int
  totalPoints     Int
  communityName   String   @db.VarChar(500)
  communityId     String   @db.VarChar(128)
  date            DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([communityId, date])
  @@map("mv_daily_community_leaders")
}
