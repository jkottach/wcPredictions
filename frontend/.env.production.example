# Used when you run: npm run build (Vite loads .env.production* automatically).
# Copy to .env.production locally, OR set these as pipeline / Azure SWA build environment variables.

# REQUIRED for Azure Static Web Apps (and most static hosts): the browser cannot use the Vite dev proxy.
# Use your App Service HTTPS origin + /api (same path prefix the Express app mounts).
VITE_API_URL=https://YOUR-BACKEND.azurewebsites.net/api

# Web client ID from Google Cloud Console (OAuth 2.0 Client IDs → Web application).
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
