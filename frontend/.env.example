# Copy to .env for local dev (gitignored)
VITE_API_URL=/api

# EC2 only: set true when using `npm run dev` behind nginx to stop tab-focus reloads
# VITE_DISABLE_HMR=true

# Local: Google button + JWT (default)
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Production Azure uses VITE_USE_AZURE_AUTH=true in .env.production instead
